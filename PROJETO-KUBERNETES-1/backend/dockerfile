# Dockerfile para o Backend PHP + Apache
FROM php:8.1-apache

# Atualiza os pacotes e instala as extensões necessárias do PHP para conectar ao MySQL (PDO)
RUN apt-get update && apt-get install -y \
    libpng-dev \
    libjpeg-dev \
    libfreetype6-dev \
    && docker-php-ext-install pdo pdo_mysql \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Habilita o mod_rewrite do Apache se necessário para URLs amigáveis
RUN a2enmod rewrite

# Define o diretório de trabalho padrão do Apache
WORKDIR /var/www/html

# Copia os arquivos de backend (lógica e conexão) para o diretório raiz do Apache no container
COPY ./conexao.php /var/www/html/
COPY ./index.php /var/www/html/

# Ajusta as permissões dos arquivos para o usuário do Apache (www-data)
RUN chown -R www-data:www-data /var/www/html

# Exposição da porta HTTP padrão
EXPOSE 80
